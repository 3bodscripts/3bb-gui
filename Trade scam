-- Toggle Creator (Bigger toggles)
local function createToggle(text, y)
	local label = Instance.new("TextLabel")
	label.Parent = frame
	label.Position = UDim2.new(0,15,0,y)
	label.Size = UDim2.new(1,-80,0,36) -- taller label
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = Color3.new(1,1,1)
	label.Font = Enum.Font.Gotham
	label.TextSize = 18 -- bigger font
	label.TextXAlignment = Enum.TextXAlignment.Left

	local toggle = Instance.new("TextButton")
	toggle.Parent = frame
	toggle.Size = UDim2.new(0,60,0,28) -- bigger toggle
	toggle.Position = UDim2.new(1,-75,0,y+4)
	toggle.BackgroundColor3 = Color3.fromRGB(70,70,70)
	toggle.Text = ""
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(1,0)

	local circle = Instance.new("Frame")
	circle.Parent = toggle
	circle.Size = UDim2.new(0,24,0,24) -- bigger circle
	circle.Position = UDim2.new(0,2,0.5,-12)
	circle.BackgroundColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)

	local state = false
	toggle.MouseButton1Click:Connect(function()
		state = not state
		if state then
			toggle.BackgroundColor3 = Color3.fromRGB(0,200,120)
			circle.Position = UDim2.new(1,-26,0.5,-12)
		else
			toggle.BackgroundColor3 = Color3.fromRGB(70,70,70)
			circle.Position = UDim2.new(0,2,0.5,-12)
		end
	end)
end

