local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/library", true))()
local window = library:CreateWindow("Rising Lava for Brainrots")

local player = game.Players.LocalPlayer

local spawnPos
player.CharacterAdded:Connect(function(char)
    local hrp = char:WaitForChild("HumanoidRootPart")
    spawnPos = hrp.CFrame
end)

window:AddButton({
    text = "TP to Base",
    callback = function()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            if spawnPos then
                hrp.CFrame = spawnPos
            else
                local spawn = workspace:FindFirstChildWhichIsA("SpawnLocation")
                if spawn then
                    hrp.CFrame = spawn.CFrame + Vector3.new(0,5,0)
                end
            end
        end
    end
})

window:AddButton({
    text = "Teleport to Eternal",
    callback = function()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(88.339317, 1129.017578, -139.963303)
        end
    end
})

window:AddButton({
    text = "Teleport to ???",
    callback = function()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(84.999680, 295.017883, -137.400146)
        end
    end
})

local lavaConn
window:AddToggle({
    text = "Remove Lava",
    state = false,
    callback = function(state)
        local lava = workspace:FindFirstChild("GameLava")
        if state then
            if lava then
                for _,v in pairs(lava:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v:Destroy()
                    end
                end
                lavaConn = lava.DescendantAdded:Connect(function(obj)
                    if obj:IsA("BasePart") then
                        task.wait()
                        obj:Destroy()
                    end
                end)
            end
        else
            if lavaConn then
                lavaConn:Disconnect()
                lavaConn = nil
            end
        end
    end
})

window:AddSlider({
    text = "WalkSpeed",
    min = 16,
    max = 250,
    value = 16,
    callback = function(speed)
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = speed
        end
    end
})

window:AddButton({
    text = "Collect Brainrot",
    callback = function()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local oldPos = hrp.CFrame
        hrp.CFrame = CFrame.new(87.338715,3495.401123,-77.677155)
        task.wait(0.05)
        hrp.CFrame = CFrame.new(86.027153,3493.817139,-141.009476)
        task.wait(0.05)
        hrp.CFrame = CFrame.new(87.338715,3495.401123,-77.677155)
        task.wait(0.05)
        hrp.CFrame = oldPos
    end
})

local autoEternal = false
local autoServerHop = false

window:AddToggle({
    text = "Auto Eternal",
    state = false,
    callback = function(state)
        autoEternal = state
    end
})

window:AddToggle({
    text = "Auto Server Hop",
    state = false,
    callback = function(state)
        autoServerHop = state
    end
})

task.spawn(function()
    while true do
        task.wait(0.2)
        if not autoEternal then continue end

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChild("Humanoid")
        if not hrp or not humanoid then continue end

        local brainrots = workspace:FindFirstChild("Brainrots")
        if not brainrots then continue end

        local eternalModels = {}
        for _,model in pairs(brainrots:GetDescendants()) do
            if model:IsA("Model") then
                local gui = model:FindFirstChildWhichIsA("BillboardGui", true)
                if gui then
                    local rarityLabel = gui:FindFirstChild("Rarity", true)
                    if rarityLabel and rarityLabel:IsA("TextLabel") and rarityLabel.Text:lower():find("eternal") then
                        table.insert(eternalModels, model)
                    end
                end
            end
        end

        for _,model in pairs(eternalModels) do
            local part = model:FindFirstChildWhichIsA("BasePart")
            local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)

            if part and prompt then
                local oldWalk = humanoid.WalkSpeed
                local oldJump = humanoid.JumpPower
                humanoid.WalkSpeed = 0
                humanoid.JumpPower = 0

                hrp.CFrame = part.CFrame + Vector3.new(0,3,0)
                task.wait(0.15)
                hrp.CFrame = CFrame.new(hrp.Position, part.Position) + Vector3.new(0,3,0)
                workspace.CurrentCamera.CFrame = CFrame.new(hrp.Position, part.Position)
                task.wait(0.1)

                fireproximityprompt(prompt, prompt.HoldDuration)
                task.wait(prompt.HoldDuration + 0.3)

                repeat task.wait(0.2) until not model.Parent

                hrp.CFrame = CFrame.new(87.338715, 3495.401123, -77.677155)
                task.wait(0.05)
                hrp.CFrame = CFrame.new(86.027153, 3493.817139, -141.009476)
                task.wait(0.05)
                hrp.CFrame = CFrame.new(87.338715, 3495.401123, -77.677155)

                humanoid.WalkSpeed = oldWalk
                humanoid.JumpPower = oldJump

                print("Collected Eternal brainrot:", model.Name)

                if autoServerHop then
                    queue_on_teleport([[
                        loadstring(game:HttpGet("YOUR_SCRIPT_LINK_HERE"))()
                    ]])
                    local TeleportService = game:GetService("TeleportService")
                    TeleportService:Teleport(game.PlaceId)
                end
            end
        end
    end
end)

window:AddLabel({
    text = "Made by 3bb",
    type = "label"
})

library:Init()
